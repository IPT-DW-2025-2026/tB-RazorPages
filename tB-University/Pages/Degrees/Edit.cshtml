@page
@model tB_University.Pages.Degrees.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Degree</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Degree.Id" />
            <input type="hidden" asp-for="Degree.LogoType"/>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Degree.Name" class="control-label"></label>
                <input asp-for="Degree.Name" class="form-control" aria-required="true"/>
                <span asp-validation-for="Degree.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                
                <label asp-for="DegreePhoto" class="control-label"></label>
                <input asp-for="DegreePhoto" accept="image/jpeg,image/png" class="form-control" />
                <span asp-validation-for="DegreePhoto" class="text-danger"></span>
                
                @{
                    /*
                     * <label asp-for="Degree.LogoType" class="control-label"></label>
                       <input asp-for="Degree.LogoType" class="form-control" />
                       <span asp-validation-for="Degree.LogoType" class="text-danger"></span>
                     */
                }
                
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
