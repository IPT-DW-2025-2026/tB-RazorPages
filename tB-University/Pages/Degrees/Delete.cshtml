@page
@model tB_University.Pages.Degrees.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Degree</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Degree.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Degree.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Degree.LogoType)
        </dt>
        <dd class="col-sm-10">
            @if (string.IsNullOrEmpty(Model.Degree.LogoType))
            {
                
            }
            else
            {
                <image width="100px" src="/@Model.Degree.LogoType"/>
            }
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="Degree.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-page="./Index">Back to List</a>
    </form>
</div>
